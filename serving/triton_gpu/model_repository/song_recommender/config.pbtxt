# Triton model config (same pattern as lab's food_classifier_onnx/config.pbtxt)
name: "song_recommender"
platform: "onnxruntime_onnx"
max_batch_size: 32

input [
  {
    name: "user_embedding"
    data_type: TYPE_FP32
    dims: [ 64 ]
  }
]

output [
  {
    name: "scores"
    data_type: TYPE_FP32
    dims: [ 10000 ]
  }
]

# Run on GPU (like lab's instance_group config)
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [ 0 ]
  }
]

# Dynamic batching (like lab's dynamic batching section)
# Groups requests that arrive within 5ms into one batch
dynamic_batching {
  max_queue_delay_microseconds: 5000
}
